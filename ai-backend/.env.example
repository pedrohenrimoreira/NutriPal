NODE_ENV=development
PORT=8787
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-5
OPENAI_WEB_MODEL=gpt-5
OPENAI_VISION_MODEL=gpt-5
OPENAI_TOOL_MODEL=gpt-5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
